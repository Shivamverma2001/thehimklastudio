# MongoDB connection string (optional: form still works without it, but data won't be stored)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/founder?retryWrites=true&w=majority

# Email notification (optional: form still works without it, but you won't get emails)
EMAIL_TO=founder@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=founder@gmail.com
# For Gmail: use an App Password, NOT your normal password. Enable 2-Step Verification, then:
# Google Account → Security → 2-Step Verification → App passwords → Generate. Use that 16-char password here.
SMTP_PASS=your-app-password
# SMTP_SECURE=false

# --- Contact & studio (shown on site; use NEXT_PUBLIC_ so they're available in the app)
NEXT_PUBLIC_CONTACT_ADDRESS="address"
NEXT_PUBLIC_CONTACT_PHONE=phone
NEXT_PUBLIC_CONTACT_EMAIL=email
NEXT_PUBLIC_CONTACT_CITY=city
NEXT_PUBLIC_CONTACT_ADDRESS_REGION=region
NEXT_PUBLIC_CONTACT_MAP_LINK=map link
NEXT_PUBLIC_CONTACT_MAP_EMBED_SRC=map embed src

# --- Founder (Meet the Founder section)
NEXT_PUBLIC_FOUNDER_NAME=name
NEXT_PUBLIC_FOUNDER_BIO=bio
NEXT_PUBLIC_FOUNDER_VISION=vision
NEXT_PUBLIC_FOUNDER_INSTAGRAM_URL=instagram url
NEXT_PUBLIC_FOUNDER_FACEBOOK_URL=facebook url
NEXT_PUBLIC_FOUNDER_YOUTUBE_URL=youtube url
NEXT_PUBLIC_FOUNDER_WEBSITE_URL=website url

# --- Social links (Footer & Connect With Us)
NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=instagram url
NEXT_PUBLIC_SOCIAL_FACEBOOK_URL=facebook url
NEXT_PUBLIC_SOCIAL_YOUTUBE_URL=youtube url
